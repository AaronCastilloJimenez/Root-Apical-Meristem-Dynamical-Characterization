class PlantSegExporter:
    def __init__(self, config: Config = CONFIG):
        self.config = config
    
    def export(self, img, filename, output_dir):
        import h5py
        
        os.makedirs(output_dir, exist_ok=True)
        
        # TIFF
        tiff_path = f"{output_dir}/{filename}.tif"
        img_uint16 = (img * 65535).astype(np.uint16) if img.max() <= 1.0 else img.astype(np.uint16)
        tifffile.imwrite(tiff_path, img_uint16, imagej=True,
                        resolution=(1.0/self.config.resolution_xy, 1.0/self.config.resolution_xy),
                        metadata={'spacing': self.config.resolution_z, 'unit': 'um', 'axes': 'ZYX'})
        
        # HDF5
        hdf5_path = f"{output_dir}/{filename}.h5"
        with h5py.File(hdf5_path, 'w') as f:
            ds = f.create_dataset('raw', data=img.astype(np.float32), compression='gzip', chunks=True)
            ds.attrs['element_size_um'] = [self.config.resolution_z, self.config.resolution_xy, self.config.resolution_xy]
            ds.attrs['axis_order'] = 'zyx'
        
        return {'tiff': tiff_path, 'hdf5': hdf5_path}

# ==============================================================================
# PIPELINE PRINCIPAL
# ==============================================================================

class CompletePipeline:
    VARIANTS = ["01_RAW", "02_BG_SUB", "03_CLAHE", "04_DOG3D", "05_TOPHAT", "06_COMBINED"]
    
    def __init__(self):
        self.filter = FilterPipeline()
        self.evaluator = StatisticalEvaluator()
        self.exporter = PlantSegExporter()
        self.all_results = {v: [] for v in self.VARIANTS}
    
    def process_file(self, filepath):
        filename = Path(filepath).stem
        print(f"\n{'='*80}")
        print(f"PROCESANDO: {filename}")
        print(f"{'='*80}")
        
        raw_img = tifffile.imread(filepath)
        print(f"Formato: {raw_img.shape} ZYX | {raw_img.dtype}")
        
        variant_images = {}
        
        for variant in self.VARIANTS:
            filtered, times = self.filter.run_variant(raw_img, variant)
            variant_images[variant] = filtered
            
            # Evaluar
            metrics = self.evaluator.compute_metrics(filtered, variant)
            self.all_results[variant].append(metrics)
            
            # Guardar debug
            debug_path = f"{CONFIG.output_dir}/filtered/{filename}_{variant}.tif"
            tifffile.imwrite(debug_path, (filtered * 65535).astype(np.uint16))
        
        # Seleccionar mejor por score ponderado
        scores = {}
        for v in self.VARIANTS:
            m = self.all_results[v][-1]
            scores[v] = (m['snr']*0.25 + m['contrast']*0.20 + m['continuity']*0.30 + 
                        m['sharpness']*0.15 + m['structure_index']*0.10)
        
        best = max(scores, key=scores.get)
        print(f"\n🏆 Mejor método: {best} (score: {scores[best]:.3f})")
        
        # Exportar mejor
        exports = self.exporter.export(variant_images[best], f"{filename}_BEST_{best}", 
                                      f"{CONFIG.output_dir}/plantseg_input")
        
        return {'filename': filename, 'best': best, 'exports': exports}
    
    def run_batch(self, pattern="*C00*.tif"):
        files = glob.glob(f"{CONFIG.input_dir}/{pattern}")
        print(f"\n🔍 {len(files)} archivos encontrados")
        
        for i, f in enumerate(files, 1):
            print(f"\n[{i}/{len(files)}] {os.path.basename(f)}")
            try:
                self.process_file(f)
            except Exception as e:
                print(f"❌ Error: {e}")
                import traceback
                traceback.print_exc()
        
        # Análisis estadístico final
        if len(files) > 0:
            print("\n" + "="*80)
            print("GENERANDO ANÁLISIS ESTADÍSTICO FINAL")
            print("="*80)
            self.evaluator.generate_full_report(self.all_results, CONFIG.output_dir)
        
        print(f"\n✅ Completado. Resultados en: {CONFIG.output_dir}/")

