@dataclass
class Config:
    input_dir: str = "~/Escritorio/imagenes_tiff_raw"
    output_dir: str = "~/Escritorio/pipeline_output"
    
    # Resolución microscopio
    resolution_xy: float = 0.3093  # µm/pixel
    resolution_z: float = 1.0      # µm/pixel
    
    # Parámetros filtros
    bg_radius_um: float = 10.0
    sigma_denoise_um: float = 0.3
    dog_sigma_small_um: float = 0.5
    dog_sigma_large_um: float = 1.5
    clahe_clip: float = 0.01
    tophat_radius_um: float = 3.0
    
    # Parámetros estadísticos
    alpha_significance: float = 0.05  # Nivel de significancia
    n_bootstrap: int = 1000           # Iteraciones bootstrap
    
    def __post_init__(self):
        self.input_dir = os.path.expanduser(self.input_dir)
        self.output_dir = os.path.expanduser(self.output_dir)
        self.anisotropy = self.resolution_z / self.resolution_xy
        self.bg_radius_px = int(self.bg_radius_um / self.resolution_xy)
        self.bg_radius_z = max(1, int(self.bg_radius_px / self.anisotropy))
        
        for subdir in ['filtered', 'evaluation', 'plantseg_input', 'statistics']:
            os.makedirs(f"{self.output_dir}/{subdir}", exist_ok=True)

CONFIG = Config()

